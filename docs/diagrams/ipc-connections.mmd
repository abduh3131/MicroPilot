flowchart TD
    subgraph Writers["Writers"]
        WC["webcam_capture.py"]
        LF["lane_follow.py"]
        EA["exp_auto.py"]
        WEB["web UI :5000"]
    end

    subgraph Files["/tmp/ files"]
        CF["/tmp/camera_frame.jpg"]
        MO["/tmp/model_output.json"]
        JS["/tmp/joystick"]
        ENG["/tmp/engage"]
        LFF["/tmp/lane_follow"]
        EXP["/tmp/exp_auto"]
    end

    subgraph Readers["Readers"]
        LF2["lane_follow.py"]
        EA2["exp_auto.py"]
        OS["output_serial.py"]
        OV["overlay_stream.py"]
    end

    WC --> CF
    LF -->|always| MO
    LF -->|"Lane Follow mode"| JS
    EA -->|"Exp Auto mode"| JS
    WEB -->|"manual joystick"| JS
    WEB --> ENG
    WEB --> LFF
    WEB --> EXP

    CF --> LF2
    MO --> EA2
    MO --> OV
    JS --> OS
    ENG --> LF2
    ENG --> EA2
    LFF --> LF2
    EXP --> EA2

    OS -->|serial| ARD["Arduino"]

