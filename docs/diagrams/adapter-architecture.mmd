flowchart TD
    LF["lane_follow.py"] -->|"adapter.run(frame)"| BA["BaseModelAdapter\n(base_adapter.py)"]

    BA --> SW["sidewalk_adapter.py\n(active on both vehicles)"]
    BA --> SC["supercombo_adapter.py\n(optional, not default)"]

    SW --> SW1["RGB input"]
    SW1 --> SW2["SegFormer inference"]
    SW2 --> SW3["Sidewalk mask"]
    SW3 --> SW4["Centerline steering"]

    SC --> SC1["YUV input"]
    SC1 --> SC2["Supercombo inference"]
    SC2 --> SC3["6120 float output"]
    SC3 --> SC4["Lane/path steering"]

    SW4 --> RET["Returns:\nsteering, confidence,\nlane_info, plan_info"]
    SC4 --> RET

    RET --> MO["/tmp/model_output.json"]

