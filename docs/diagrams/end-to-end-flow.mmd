    style D fill:#1b4332,color:#fff,stroke:#0d2618
    style E fill:#1a1a2e,color:#fff,stroke:#0d0d1a
    style F fill:#7b2d26,color:#fff,stroke:#4a1a17
    style G fill:#1a1a2e,color:#fff,stroke:#0d0d1a
